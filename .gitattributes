# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files to ensure consistent line endings
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.toml text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp4 binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Keep Windows batch files with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

